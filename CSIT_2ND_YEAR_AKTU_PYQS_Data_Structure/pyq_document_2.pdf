class="ask-doubt-vertical">
Ask Doubt
</a><style>/* Wrapper */
.float-social-wrapper{
  position:fixed;
  top:60%;
  right:0;
  transform:translateY(-50%);
  display:flex;
  flex-direction:column;
  z-index:1000;
}

/* Common Button */
.float-btn{
  width:38px;
  height:38px;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
}

.float-btn img{
  width:18px;
  height:18px;
}

/* Colors */

.whatsapp-btn{
  background:#25d366;
  border-top-left-radius:10px;
}

.telegram-btn{
  background:#0088cc;
}

.share-btn{
  background:#e53935;
  border-bottom-left-radius:10px;
}

.share-btn img{
  filter:brightness(0) invert(1);
}

.ask-doubt-vertical{
  position: fixed;
  right: 0;
  top: 40%;
  transform: translateY(-50%) rotate(180deg); /* 🔥 ulta direction */
  
  background: #4A67FF;
  color: white;
  
  padding: 12px 6px;
  font-size: 14px;
  font-weight: 600;
  
  writing-mode: vertical-rl;
  text-orientation: mixed;
  
  border-top-right-radius: 10px;
  border-bottom-right-radius: 10px;
  
  z-index: 1001;
  text-decoration: none;
  
  box-shadow: 0 4px 10px rgba(0,0,0,0.2);
}

.ask-doubt-vertical:hover{
  background: #3b55e0;
}

/* Mobile Fix */
@media(max-width:768px){

  .float-social-wrapper{
    bottom:150px;
    top:auto;
    transform:none;
  }

  .ask-doubt-vertical{
    top:40%;
  }

}</style></div> <script type="speculationrules">{"prefetch":[{"source":"document","where":{"and":[{"href_matches":"/*"},{"not":{"href_matches":["/wp-*.php","/wp-admin/*","/wp-content/uploads/*","/wp-content/*","/wp-content/plugins/*","/wp-content/themes/astra/*","/*\\?(.+)"]}},{"not":{"selector_matches":"a[rel~=\"nofollow\"]"}},{"not":{"selector_matches":".no-prefetch, .no-prefetch a"}}]},"eagerness":"conservative"}]}</script> <div id="ezoic-pub-ad-placeholder-179" data-inserter-version="-1" data-placement-location="native_bottom"></div><script data-ezoic="1" data-no-optimize="1" data-no-defer="1">ezstandalone.cmd.push(function () { ezstandalone.showAds(179); });</script><div id="ezoic-pub-ad-placeholder-120" data-inserter-version="-1" data-placement-location="bottom_of_page"></div><script data-ezoic="1" data-no-optimize="1" data-no-defer="1">ezstandalone.cmd.push(function () { ezstandalone.showAds(120); });</script><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 0 0" width="0" height="0" focusable="false" role="none" style="visibility: hidden; position: absolute; left: -9999px; overflow: hidden;" ><defs><filter id="ast-img-color-filter-2"><feColorMatrix color-interpolation-filters="sRGB" type="matrix" values=" .299 .587 .114 0 0 .299 .587 .114 0 0 .299 .587 .114 0 0 .299 .587 .114 0 0 " /><feComponentTransfer color-interpolation-filters="sRGB" ><feFuncR type="table" tableValues="1 1" /><feFuncG type="table" tableValues="1 1" /><feFuncB type="table" tableValues="1 1" /><feFuncA type="table" tableValues="1 1" /></feComponentTransfer><feComposite in2="SourceGraphic" operator="in" /></filter></defs></svg><div data-elementor-type="popup" data-elementor-id="39152" class="elementor elementor-39152 elementor-location-popup" data-elementor-settings="{&quot;a11y_navigation&quot;:&quot;yes&quot;,&quot;timing&quot;:[]}" data-elementor-post-type="elementor_library"><div class="elementor-element elementor-element-70aecec4 e-flex e-con-boxed e-con e-parent" data-id="70aecec4