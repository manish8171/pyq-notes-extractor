ript> <link rel="icon" href="https://notesgallery.com/wp-content/uploads/2025/02/cropped-cropped-notebook-3-e1740403641906-60x60.png" sizes="32x32" /><link rel="icon" href="https://notesgallery.com/wp-content/uploads/2025/02/cropped-cropped-notebook-3-e1740403641906.png" sizes="192x192" /><link rel="apple-touch-icon" href="https://notesgallery.com/wp-content/uploads/2025/02/cropped-cropped-notebook-3-e1740403641906.png" /><meta name="msapplication-TileImage" content="https://notesgallery.com/wp-content/uploads/2025/02/cropped-cropped-notebook-3-e1740403641906.png" /><style id="wp-custom-css">.desktopx{
	display:block;
	
}
.mobilex{
	display:none;
}
	
@media (max-width: 768px) {
	.desktopx{
	display:none;

}
.mobilex{
	display:block;
}
}
	

#preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh; /* mobile fix */
    background: #ffffff;
    z-index: 999999;
    display: flex;
    justify-content: center;
    align-items: center;
}

.loader {
    width: 45px;
    height: 45px;
    border: 4px solid #eee;
    border-top: 4px solid #ff4d4d;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    100% { transform: rotate(360deg); }
}

/* Remove left & right gap ONLY on homepage */
body.elementor-page-38629 .site,
body.elementor-page-38629 .site-content,
body.elementor-page-38629 .content-area,
body.elementor-page-38629 .container,
body.elementor-page-38629 .ast-container,
body.elementor-page-38629 .wrap {
    max-width: 100% !important;
    width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
}

/* Remove body margin only for homepage */
body.elementor-page-38629 {
    margin: 0 !important;
    padding: 0 !important;
}


@media (max-width: 767px) {

.elementor-section {
    display: flex !important;
    align-items: center !important;
}

.elementor-column {
    display: flex !important;
    align-items: center !important;
}

.elementor-widget-wrap {
    justify-content: space-between !important;
}

}





/* Desktop */
@media (min-width: 769px) {
    .mwai-trigger.mwai-open-button {
        position: fixed !important;
        bottom: 20px !important;
        right: 20px !important;
        left: auto !important;
        transform: scale(1) !important;
        z-index: 999999 !important;
    }
}

/* Mobile */
@media (max-width: 768px) {
    body .mwai-trigger.mwai-open-button,
    body .mwai-trigger.mwai-open-button .mwai-icon-container {
			display: none !important
        position: fixed !important;
        bottom: 60px !important;
        left: 20px !important;
        right: auto !important;
        transform: scale(0.9) !important;
        z-index: 999999 !important;
    }
}



/* Optional: Adjust for small screens */
@media (max-width: 768px) {
  .float-social-wrapper {
    bottom: 70px;
    top: auto;
    transform: none;
  }

  .float-btn {
    width: 48px;   /* पहले 38px था */
    height: 48px;
    padding: 8px;  /* थोड़ा बढ़ाया */
  }

  .float-btn img {
    width: 24px;   /* पहले 18px था */
    height: 24px;
  }
}


.ads-left, .ads-right {
  position: fixed;
  top: 145px; /* Adjust this according to your Astra header height */
  width: 160px;
  height: 600px;
  z-index: 999;
  display: none;
  background: transparent;
  box-shadow: 0 0 0px rgba(0,0,0,0.0);
}

/* Desktop only */
@media (min-width: 1024px) {
  .ads-left {
    left: 10px;
    display: block;
  }

  .ads-right {
    right: 10px;
    display: block;
  }
}

/* Hide ads near footer using JS */
body.hide-ads .ads-left,
body.hide-ads .ads-right {
  display: none !important;
}

/* Close button */
.close-ad {
  position: absolute;
  top: 2px;
  right: 5px;
  background: transparent;
  color: transparent;
  border: none;
  font-size: 18px;
  line-height: 1;
  padding: 2px 6px;
  cursor: pointer;
  z-index: 10000;
  border-radius: 0%;
}





/* Comment section के ऊपर की spacing कम करें */
.single-post .comments-area {
  margin-top: 20px !important;
}

/* Featured Image पर Shadow */
.single-post .post-thumb img {
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
  border-radius: 8px;
  display: block;
}

/* पोस्ट के अंदर की सिर्फ main images पर shadow, emoji पर नहीं */
.single-post .entry-content p > img,
.single-post .entry-content figure img,
.single-post .entry-content .wp-block-image img {
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
  border-radius: 8px;
  display: block;
  margin: 1em auto;
}

/* inline emojis को छोड़ने के लिए inline img पर कोई shadow नहीं */
.single-post .entry-content img.emoji,
.single-post .entry-content img.inline,
.single-post .entry-content span img {
  box-shadow: none !important;
  border-radius: 0 !important;
}

/* Comment Box */
.comment-respond {
  background-color: #f9f9fb;
  border: 2px solid #e1e1e1;
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}

.comment-respond h3 {
  font-size: 24px;
  margin-bottom: 20px;
  color: #333;
  font-weight: 600;
}
.comment-form label {
  font-weight: 500;
  display: block;
  margin-bottom: 6px;
  color: #555;
}
.comment-form input,
.comment-form textarea {
  width: 100%;
  padding: 12px 14px;
  border: 1px solid #ccc;
  border-radius: 10px;
  margin-bottom: 20px;
  background-color: #fff;
  transition: border-color 0.3s ease;
}
.comment-form input:focus,
.comment-form textarea:focus {
  border-color: #007bff;
  outline: none;
  box-shadow: 0 0 5px rgba(0, 123, 255, 0.2);
}
.comment-form textarea {
  min-height: 150px;
  resize: vertical;
}
.comment-form-cookies-consent {
  font-size: 14px;
  color: #666;
  margin-bottom: 20px;
}
.comment-form input[type="submit"] {
  background-color: #007bff;
  color: #fff;
  padding: 12px 28px;
  font-size: 16px;
  font-weight: 600;
  border-radius: 50px;
  cursor: pointer;
  transition: background-color 0.3s, transform 0.2s;
  box-shadow: 0 4px 10px rgba(0, 123, 255, 0.2);
}
.comment-form input[type="submit"]:hover {
  background-color: #0056b3;
  transform: translateY(-2px);
}
.comment-form input[type="submit"]:active {
  transform: translateY(0);
  box-shadow: 0 2px 5px rgba(0, 123, 255, 0.2);
}
.comment-form-url {
  display: none !important;
}

/* Fix list left overflow in Astra single blog post */
.single-post .entry-content ul,
.single-post .entry-content ol {
  margin-left: 5px;
  padding-left: 5px;
  list-style-position: inside;
}

/* Improve spacing and readability of list items */
.single-post .entry-content ul li,
.single-post .entry-content ol li {
  margin-bottom: 10px;
  line-height: 1.6;
}

/* Import Poppins Font */
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

/* Apply Poppins to Body */
body {
  font-family: 'Poppins', sans-serif;
}
.ribbon-pop { display: none !important; }</style></head><body itemtype='https://schema.org/WebPage' itemscope='itemscope' class="wp-singular page-template-default page page-id-35365 page-child parent-pageid-30522 wp-custom-logo wp-embed-responsive wp-theme-astra angie-default ast-desktop ast-page-builder-template ast-no-sidebar astra-4.13.1 group-blog ast-single-post ast-replace-site-logo-transparent ast-inherit-site-logo-transparent ast-hfb-header ast-full-width-primary-header ast-full-width-layout ast-inherit-site-logo-sticky elementor-page-40930 elementor-default elementor-kit-29762 elementor-page elementor-page-35365 astra-addon-4.12.2"> <script type="litespeed/javascript">(function(){var w=document.documentElement.clientWidth;if(w>0&&w<=921){document.body.classList.add('ast-header-break-point');document.body.classList.remove('ast-desktop')}})()</script> <a
